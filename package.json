{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "surgent",
  "description": "Surgent monorepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "typecheck": "bun turbo typecheck",
    "prepare": "husky",
    "random": "echo 'Random script'",
    "hello": "echo 'Hello World!'"
  },
  "devDependencies": {
    "husky": "9.1.7",
    "prettier": "^3.6.2",
    "turbo": "^2.5.6",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.2.20",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@hono/mcp": "^0.2.3",
    "@modelcontextprotocol/sdk": "^1.25.1",
    "@opencode-ai/plugin": "^0.15.14",
    "@opencode-ai/sdk": "^0.15.14",
    "@stripe/ui-extension-sdk": "^9.1.0",
    "autumn-js": "^0.1.47",
    "convex": "^1.28.0",
    "monaco-themes": "^0.4.7"
  },
  "prettier": {
    "semi": false,
    "printWidth": 120
  },
  "catalog": {
    "@tsconfig/bun": "^1.0.7",
    "@types/bun": "^1.2.19",
    "@typescript/native-preview": "^7.0.0-dev.20250608.1",
    "typescript": "^5.9.2",
    "@hono/zod-validator": "^0.5.0",
    "@octokit/rest": "^22.0.0",
    "@openauthjs/openauth": "*",
    "@pierre/diffs": "*",
    "ai": "^5.0.0",
    "diff": "^8.0.2",
    "hono": "^4.8.0",
    "hono-openapi": "*",
    "remeda": "^2.28.0",
    "ulid": "^2.3.0",
    "zod": "^3.25.28"
  }
}
