{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "surgent",
  "description": "Surgent monorepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "typecheck": "bun turbo typecheck",
    "prepare": "husky",
    "db:migrate": "bun --filter @repo/db db:migrate",
    "db:rollback": "bun --filter @repo/db db:rollback",
    "trustmrr:sync": "bun scripts/trustmrr-sync.ts"
  },
  "devDependencies": {
    "@tsconfig/bun": "1.0.10",
    "husky": "9.1.7",
    "lint-staged": "16.2.7",
    "prettier": "3.8.1",
    "turbo": "2.8.0",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@ai-sdk/provider": "2.0.0",
    "@ai-sdk/provider-utils": "3.0.19",
    "@aws-sdk/s3-request-presigner": "3.978.0",
    "@hono/mcp": "0.2.3",
    "@modelcontextprotocol/sdk": "1.25.3",
    "@opencode-ai/plugin": "0.15.31",
    "@opencode-ai/sdk": "0.15.31",
    "ai": "5.0.97",
    "convex": "1.34.0",
    "entrijs": "1.0.0",
    "monaco-themes": "0.4.8",
    "react-simple-maps": "3.0.0",
    "sonner": "2.0.7"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "printWidth": 100
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md}": "prettier --write"
  },
  "overrides": {
    "@codemirror/state": "6.5.4",
    "@codemirror/view": "6.39.11"
  },
  "catalog": {
    "@tsconfig/bun": "^1.0.7",
    "@types/bun": "^1.2.19",
    "@typescript/native-preview": "^7.0.0-dev.20250608.1",
    "typescript": "^5.9.2",
    "@hono/zod-validator": "^0.5.0",
    "@octokit/rest": "^22.0.0",
    "@openauthjs/openauth": "*",
    "@pierre/diffs": "*",
    "ai": "5.0.97",
    "diff": "^8.0.2",
    "hono": "^4.8.0",
    "hono-openapi": "*",
    "remeda": "^2.28.0",
    "ulid": "^2.3.0",
    "zod": "^4.1.0"
  }
}
