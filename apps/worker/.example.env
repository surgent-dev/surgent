DATABASE_URL='xxx'
POSTGRES_TYPE="pg" # or neon

OPENCODE_BASE_URL=xxx
SURGENT_BASE_URL=xxx

GOOGLE_GENERATIVE_AI_API_KEY=xxx
OPENAI_API_KEY=xxx

# GITHUB 
GITHUB_APP_ID=xxx
GITHUB_APP_SLUG=surgent-app
GITHUB_WEBHOOK_SECRET=xxx
GITHUB_STATE_SECRET=xxx
