GITHUB_CLIENT_ID=xxx
GITHUB_CLIENT_SECRET=xxx

PORT=4000

E2B_TEMPLATE=surgent-v1-0-0
E2B_API_KEY=xxx

# Sandbox preview proxy domain (e.g., surgent.dev)
# When set, preview URLs become: https://{port}-{sandboxId}.{SANDBOX_PREVIEW_DOMAIN}
SANDBOX_PREVIEW_DOMAIN=surgent.dev
