# Local development environment variables
#
# INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.test .env
# 2. Replace the placeholder values below with your actual values
# 3. DO NOT commit the .env file to git (it contains secrets)
# 4. Run this command to set the production secret:
#    echo <YOUR_ACTUAL_TOKEN> | wrangler secret put CLOUDFLARE_API_TOKEN

# Replace with your actual Cloudflare account ID
CLOUDFLARE_ACCOUNT_ID=44756fda18d37b7accae2ce6baf0ac6a

# Replace with your actual API token (Workers Scripts: Edit permission required) or use Local OAUTH
# To create: Workers dashboard -> API Tokens -> Create Token -> Custom -> Account: Workers Scripts: Edit
# CLOUDFLARE_API_TOKEN=xxx

DAYTONA_API_KEY=xxx

DAYTONA_API_URL=https://app.daytona.io/api
DAYTONA_ORG_ID=xxx


GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx

BETTER_AUTH_SECRET=xxx
BETTER_AUTH_URL=Backend_URL

DATABASE_URL=xxx

CLIENT_ORIGIN=Frontend_URL

CONVEX_TEAM_TOKEN=xxx
CONVEX_TEAM_ID=xxx
CONVEX_HOST=https://api.convex.dev

Z_AI_API_KEY=xxx
Z_AI_BASE_URL=https://api.z.ai/api/anthropic

AUTUMN_SECRET_KEY=xxx

OPENAI_API_KEY=xxxx

GOOGLE_API_KEY=xxx

GOOGLE_GENERATIVE_AI_API_KEY=xxx

DAYTONA_SNAPSHOT=default-env:1.0.3

POSTGRES_TYPE=pg

GITHUB_APP_ID=xxx
GITHUB_APP_SLUG=surgent-app
GITHUB_WEBHOOK_SECRET=xxx
GITHUB_STATE_SECRET=xxx
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----xxx----END RSA PRIVATE KEY-----"

GITHUB_CLIENT_ID=xxx
GITHUB_CLIENT_SECRET=xxx

PORT=4000
