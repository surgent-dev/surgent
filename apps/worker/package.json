  "scripts": {
    "check-db": "bun ../../packages/db/src/migrate.ts check",
    "archive:opencode-sync": "bun scripts/archive-opencode-sync-entity.ts",
    "dev": "APP_DEBUG=true bun --hot src/index.ts",
    "migrate-db": "bun ../../packages/db/src/migrate.ts",
    "rollback-db": "bun ../../packages/db/src/migrate.ts down",
    "start": "bun src/index.ts",
    "start-docker": "bun run check-db && SKIP_DB_MIGRATION=1 bun src/index.ts",
    "e2b:build:dev": "bun run src/e2b/build.ts",
    "e2b:build:prod": "NODE_ENV=production bun run src/e2b/build.ts",
    "e2b:build:dev-sandbox": "bun run src/e2b/build.dev.ts",
    "typecheck": "tsc --noEmit",
    "check-types": "bun run typecheck",
    "test:unit": "bun test src/routes/pay/__tests__/webhooks.test.ts src/routes/pay/__tests__/handlers.test.ts src/controllers/__tests__/projects.test.ts src/lib/__tests__/sandbox-health.test.ts",
    "test:db": "bun test src/routes/pay/__tests__/checkout.test.ts src/routes/pay/__tests__/webhook.test.ts"
  }
}
