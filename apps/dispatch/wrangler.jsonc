{
  "name": "dispatch",
  "main": "src/index.ts",
  "tsconfig": "./tsconfig.json",
  "compatibility_date": "2025-10-21",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "routes": ["*.surgent.site/*"],
  "preview_urls": true,
  "workers_dev": true,
  "dispatch_namespaces": [
    {
      "binding": "dispatcher",
      "namespace": "default-surgent-namespace",
      "remote": true
    }
  ]
}
