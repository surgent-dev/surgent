  "query": "\n        SELECT id, \"processorPriceId\", \"priceAmount\", \"recurringInterval\" as \"recurring_interval: Option<RecurringInterval>\"\n        FROM product_price\n        WHERE \"productId\" = $1 AND ($2::text IS NULL OR slug = $2)\n        ORDER BY \"createdAt\" ASC\n        LIMIT 1\n        ",
