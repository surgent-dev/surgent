{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT p.id, p.name, p.description, p.slug, p.\"productGroup\", p.version, p.\"processorProductId\"\n        FROM product p\n        WHERE p.\"productGroup\" = $1\n          AND p.\"projectId\" = $2\n        ORDER BY p.version DESC NULLS LAST\n        LIMIT 1\n        ",
