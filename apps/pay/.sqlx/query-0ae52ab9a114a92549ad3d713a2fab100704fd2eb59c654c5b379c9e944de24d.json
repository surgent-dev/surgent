{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT id\n        FROM subscription\n        WHERE \"customerId\" = $1\n          AND \"productId\" = $2\n          AND status = ANY($3::subscription_status[])\n          AND \"projectId\" = $4\n        LIMIT 1\n        ",
  "describe": {
    "columns": [
      {
        "ordinal": 0,
        "name": "id",
        "type_info": "Uuid"
      }
    ],
    "parameters": {
