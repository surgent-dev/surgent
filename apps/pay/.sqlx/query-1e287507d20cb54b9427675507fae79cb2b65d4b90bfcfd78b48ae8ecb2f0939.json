{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT id, \"processorPriceId\", \"priceAmount\", \"recurringInterval\" as \"recurring_interval: Option<RecurringInterval>\"\n        FROM product_price\n        WHERE \"productId\" = $1\n          AND ($2::text IS NULL OR id = $3 OR slug = $2)\n        ORDER BY\n            (id = $3)::int DESC,\n            (slug = $2)::int DESC,\n            \"createdAt\" ASC\n        LIMIT 1\n        ",
