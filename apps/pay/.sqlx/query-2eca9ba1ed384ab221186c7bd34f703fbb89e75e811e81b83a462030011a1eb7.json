  "query": "\n        SELECT p.id, p.\"projectId\", p.name\n        FROM product p\n        WHERE p.\"projectId\" = $1\n          AND (p.id = $2 OR p.slug = $3)\n        ORDER BY (p.id = $2)::int DESC\n        LIMIT 1\n        ",
