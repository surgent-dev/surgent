{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            s.id,\n            s.\"projectId\",\n            s.\"productId\",\n            s.\"productPriceId\",\n            s.\"customerId\",\n            s.\"processorSubscriptionId\",\n            s.\"processorCustomerId\",\n            s.\"createdAt\",\n            s.\"deletedAt\",\n            s.\"currentPeriodStart\",\n            s.\"currentPeriodEnd\",\n            s.\"canceledAt\",\n            s.\"endedAt\",\n            s.status as \"status: SubscriptionStatus\"\n        FROM subscription s\n        WHERE s.\"customerId\" = $1\n        ORDER BY s.\"createdAt\" DESC\n        ",
