  "query": "\n        SELECT \"projectId\", \"productId\", status as \"status: CheckoutStatus\", \"processorCheckoutId\", mode as \"mode: CheckoutMode\"\n        FROM checkout_session\n        WHERE \"projectId\" = $1\n        ORDER BY \"createdAt\" DESC\n        LIMIT 1\n        ",
