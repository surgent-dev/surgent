#!/bin/sh
# Pre-push hook: Verify .sqlx/ cache is up-to-date for offline compilation

# Check if sqlx-cli is installed
if ! command -v cargo-sqlx >/dev/null 2>&1 && ! cargo sqlx --version >/dev/null 2>&1; then
    echo "Warning: sqlx-cli not installed, skipping .sqlx/ cache check"
    echo "Install with: cargo install sqlx-cli"
    exit 0
fi

# Check if .sqlx/ is up-to-date
if ! cargo prepare-check 2>&1; then
    echo ""
    echo "=========================================="
    echo ".sqlx/ cache is out of date - Auto-fixing..."
    echo "=========================================="
    echo ""

    echo "Updating .sqlx/ cache..."
    if ! cargo prepare 2>&1; then
        echo ""
        echo "ERROR: Failed to update .sqlx/ cache"
        exit 1
    fi

    echo ""
    echo "Staging .sqlx/ changes..."
    if ! git add .sqlx/ 2>&1; then
        echo ""
        echo "ERROR: Failed to stage .sqlx/ changes"
        exit 1
    fi

    echo ""
    echo "Amending last commit with updated .sqlx/ cache..."
    if ! git commit --amend --no-edit 2>&1; then
        echo ""
        echo "ERROR: Failed to amend commit"
        exit 1
    fi

    echo ""
    echo "=========================================="
    echo "Auto-fixed: .sqlx/ cache updated and commit amended"
    echo "=========================================="
    echo ""
fi
