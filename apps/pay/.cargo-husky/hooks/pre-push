#!/bin/sh
# Pre-push hook: Verify .sqlx/ cache is up-to-date for offline compilation

# Check if sqlx-cli is installed
if ! command -v cargo-sqlx >/dev/null 2>&1 && ! cargo sqlx --version >/dev/null 2>&1; then
    echo "Warning: sqlx-cli not installed, skipping .sqlx/ cache check"
    echo "Install with: cargo install sqlx-cli"
    exit 0
fi

# Check if .sqlx/ is up-to-date
if ! cargo prepare-check 2>&1; then
    echo ""
    echo "=========================================="
    echo ".sqlx/ cache is out of date - PLEASE FIX..."
    echo "=========================================="
    echo ""
fi
