{
  "name": "pay",
  "version": "0.2.0",
  "scripts": {
    "build": "cargo build --release --locked --bin surpay",
    "dev": "RUST_LOG=surpay=debug cargo watch -q -c -w src -x run",
    "test": "cargo nextest run --all-targets --all-features",
    "lint": "cargo clippy --all-targets --all-features -- -D warnings",
    "check-types": "cargo check --all-targets --all-features",
    "fmt": "cargo fmt --all --check",
    "fmt:fix": "cargo fmt --all",
    "sqlx:prepare": "cargo prepare",
    "sqlx:check": "cargo prepare-check",
    "postinstall": "command -v sqlx >/dev/null || cargo install sqlx-cli cargo-watch cargo-nextest --locked"
  }
}
