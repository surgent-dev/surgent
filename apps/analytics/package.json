{
  "name": "@surgent/analytics",
  "version": "0.1.0",
  "description": "Surgent Analytics headless backend.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "start": "bun run build-db && bun run build-tracker && bun run check-db && bun run serve",
    "dev": "bun run build-db && bun run build-tracker && bun run check-db && bun --hot src/server/index.ts",
    "build": "bun run check-env && bun run build-db && bun run check-db && bun run build-tracker && bun run build-geo",
    "check-types": "bunx tsc --noEmit",
    "typecheck": "bun run check-types",
    "build-docker": "SKIP_DB_CHECK=1 bun run check-env && bun run build-db && bun run build-tracker && bun run build-geo",
    "start-docker": "SKIP_DB_MIGRATION=1 bun run check-db && bun run serve",
    "build-tracker": "bunx rollup -c rollup.tracker.config.js",
    "build-geo": "bun scripts/build-geo.js",
    "build-db": "bun run build-db-client && bun run build-prisma-client",
    "build-db-client": "bunx prisma generate",
    "build-db-schema": "bunx prisma db pull",
    "build-prisma-client": "bun scripts/build-prisma-client.js",
    "update-db": "bunx prisma migrate deploy",
    "check-db": "bun scripts/check-db.js",
    "migrate-storage": "bun run check-db",
    "check-env": "bun scripts/check-env.js",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write",
    "test": "jest",
    "seed-data": "bun scripts/seed-data.ts",
    "dev:analytics": "bun run dev",
    "build:analytics": "bun run build",
    "serve": "bun src/server/index.ts"
  },
  "dependencies": {
    "@clickhouse/client": "^1.12.0",
    "@date-fns/utc": "^1.2.0",
    "@prisma/adapter-pg": "^6.18.0",
    "@prisma/client": "^6.18.0",
    "@prisma/extension-read-replicas": "^0.4.1",
    "@umami/redis-client": "^0.29.0",
    "chalk": "^5.6.2",
    "date-fns": "4.3.0",
    "date-fns-tz": "3.2.0",
    "debug": "^4.4.3",
    "detect-browser": "^5.2.0",
    "dotenv": "^17.2.3",
    "hono": "4.12.23",
    "ipaddr.js": "^2.3.0",
    "is-localhost-ip": "^2.0.0",
    "isbot": "^5.1.31",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "kafkajs": "^2.1.0",
    "maxmind": "^5.0.0",
    "papaparse": "^5.5.3",
    "pg": "^8.16.3",
    "prisma": "^6.18.0",
    "pure-rand": "^7.0.1",
    "request-ip": "^3.3.0",
    "semver": "^7.7.3",
    "ua-parser-js": "^2.0.6",
    "uuid": "11.1.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@rollup/plugin-replace": "^5.0.2",
    "@rollup/plugin-terser": "^0.4.4",
    "@types/bun": "^1.3.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.9.2",
    "esbuild": "^0.25.11",
    "jest": "^29.7.0",
    "rollup": "^4.52.5",
    "tar": "7.5.15",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "private": true
}
