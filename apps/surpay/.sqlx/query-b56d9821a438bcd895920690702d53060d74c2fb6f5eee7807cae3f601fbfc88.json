  "query": "\n        SELECT\n            c.id,\n            c.project_id,\n            c.email,\n            c.name,\n            c.processor_customer_id\n        FROM customer c\n        INNER JOIN project p ON c.project_id = p.id\n        WHERE c.project_id = $1\n          AND p.organization_id = $2\n        ",
