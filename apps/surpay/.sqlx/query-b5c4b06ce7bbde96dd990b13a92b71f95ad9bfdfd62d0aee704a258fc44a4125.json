{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            t.id,\n            t.created_at,\n            t.type as \"type_: TransactionType\",\n            t.amount,\n            t.currency\n        FROM transaction t\n        WHERE t.customer_id = $1\n          AND t.type = 'payment'\n        ORDER BY t.created_at DESC\n        ",
