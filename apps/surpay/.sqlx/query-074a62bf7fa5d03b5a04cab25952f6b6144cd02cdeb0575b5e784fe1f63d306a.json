  "query": "\n            SELECT\n                o.id,\n                o.name,\n                o.slug,\n                o.\"createdBy\",\n                o.\"platformFeePercent\",\n                o.\"platformFeeFixed\",\n                a.\"key\"\n            FROM organization o\n            JOIN apikey a ON a.\"organizationId\" = o.id\n            WHERE a.prefix = $1\n            ",
