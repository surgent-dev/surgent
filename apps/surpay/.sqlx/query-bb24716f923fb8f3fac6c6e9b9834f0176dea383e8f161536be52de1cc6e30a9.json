{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            t.id,\n            t.\"createdAt\",\n            t.type as \"type_: TransactionType\",\n            t.amount,\n            t.currency\n        FROM transaction t\n        WHERE t.\"customerId\" = $1\n          AND t.type = 'payment'\n        ORDER BY t.\"createdAt\" DESC\n        ",
