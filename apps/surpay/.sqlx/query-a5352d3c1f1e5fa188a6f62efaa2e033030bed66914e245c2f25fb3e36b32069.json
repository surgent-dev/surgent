{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            s.id,\n            s.created_at,\n            s.current_period_start,\n            s.current_period_end,\n            s.status as \"status: SubscriptionStatus\",\n            s.processor_subscription_id\n        FROM subscription s\n        WHERE s.customer_id = $1\n        ORDER BY s.created_at DESC\n        ",
