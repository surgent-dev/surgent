{
  "name": "@repo/db",
  "exports": {
    ".": "./index.ts",
    "./migrate": "./src/migrate.ts"
  },
  "type": "module",
  "scripts": {
    "db:migrate": "bun ./src/migrate.ts",
    "db:check": "bun ./src/migrate.ts check",
    "db:rollback": "bun ./src/migrate.ts down",
    "typecheck": "tsc --noEmit",
    "check-types": "bun run typecheck"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "dotenv": "^17.2.3",
    "kysely": "0.29.2",
    "kysely-neon": "^2.0.2",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^20",
    "@types/pg": "^8.11.10"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "private": true
}
